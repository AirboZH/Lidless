{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lidless",
  "version": "0.1.0",
  "identifier": "cc.lidless.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Lidless",
        "width": 360,
        "height": 460,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "visible": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://api.lidless.cc/update/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVGQzY2NkIzNEI2NDdBOTQKUldTVWVtUkxzMmJHWHdUdElOWTZ5d1JERDZGeWFNT2o4QVRib3VCTUczbllZNWJXV01TYVp6eUMK"
    }
  }
}
