# ── Site ────────────────────────────────────────────────
# Canonical domain, used for canonical / hreflang / sitemap / OG (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://lidless.app

# The real download link that the primary "Download for macOS" CTA points to (a .dmg or a Release page)
# TODO: replace with your real download link
NEXT_PUBLIC_DOWNLOAD_URL=https://github.com/AirboZH/Lidless/releases/latest

# GitHub repository
NEXT_PUBLIC_GITHUB_URL=https://github.com/AirboZH/Lidless

# Optional: Twitter / X username (including @), used for OG twitter:creator
NEXT_PUBLIC_TWITTER=

# ── Telemetry (optional) ────────────────────────────────
# VibeLoft Web Telemetry for the hosted production site (https://lidless.app).
# Leave both empty (the default) and no telemetry script is rendered at all —
# forks, local dev and preview deployments stay telemetry-free.
# The auth key is a revocable, product-scoped browser write key (it ships in the
# public HTML by design), but keep real values out of the repo: set both only in
# the deployment platform (e.g. Vercel → Environment Variables, Production scope).
NEXT_PUBLIC_VIBELOFT_PRODUCT_ID=
NEXT_PUBLIC_VIBELOFT_AUTH_KEY=
