# ── 站点 ────────────────────────────────────────────────
# 规范域名，用于 canonical / hreflang / sitemap / OG（结尾不要带斜杠）
NEXT_PUBLIC_SITE_URL=https://lidless.cc

# 主 CTA「Download for macOS」指向的真实下载链接（.dmg 或 Release 页）
# TODO: 换成你的真实下载链接
NEXT_PUBLIC_DOWNLOAD_URL=https://github.com/AirboZH/Lidless/releases/latest

# GitHub 仓库
NEXT_PUBLIC_GITHUB_URL=https://github.com/AirboZH/Lidless

# 可选：Twitter / X 用户名（含 @），用于 OG twitter:creator
NEXT_PUBLIC_TWITTER=

# ── Sanity（可选，不填则用 demo 用例数据）─────────────────
# 填了 PROJECT_ID 才会启用 Sanity；其余有默认值
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
