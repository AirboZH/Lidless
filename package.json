{
  "name": "lidless-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Lidless monorepo：桌面端锁屏保活 app (apps/desktop) 与官网 (apps/web)",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "desktop": "pnpm --filter @lidless/desktop",
    "desktop:dev": "pnpm --filter @lidless/desktop dev",
    "desktop:build": "pnpm --filter @lidless/desktop build",
    "web": "pnpm --filter @lidless/web",
    "web:dev": "pnpm --filter @lidless/web dev",
    "web:build": "pnpm --filter @lidless/web build",
    "web:start": "pnpm --filter @lidless/web start",
    "web:lint": "pnpm --filter @lidless/web lint"
  }
}
